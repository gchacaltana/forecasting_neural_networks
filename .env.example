# Copy this file to `.env` and adjust values for your environment.
# Never commit `.env` (it is gitignored).

# -----------------------------------------------------------------------------
# Dataset (JSON)
# -----------------------------------------------------------------------------
WC_DATA_FILE=data/water_consumption.json

# -----------------------------------------------------------------------------
# Neural network defaults
# (CLI prompts can still override these at runtime)
# -----------------------------------------------------------------------------
NN_DEFAULT_EPOCHS=60
NN_DEFAULT_TRAIN_PREDICTIVE_MONTHS=3
NN_DEFAULT_TRAIN_PERCENTAGE=80
NN_DEFAULT_TEST_PERCENTAGE=20
NN_DEFAULT_ACTIVATION=tanh
NN_DEFAULT_OPTIMIZER=Adam
NN_DEFAULT_LOSS=mean_absolute_error
NN_FEATURE_RANGE_MIN=-1
NN_FEATURE_RANGE_MAX=1
NN_PREDICTION_DECIMAL_PLACES=3

# -----------------------------------------------------------------------------
# TensorFlow logging (0=all, 1=info, 2=warnings, 3=errors)
# -----------------------------------------------------------------------------
TF_CPP_MIN_LOG_LEVEL=3
